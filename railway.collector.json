{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.worker",
    "watchPatterns": [
      "Dockerfile.worker",
      "package.json",
      "package-lock.json",
      "railway.collector.json",
      "worker/**"
    ]
  },
  "deploy": {
    "startCommand": "npm run worker:collect",
    "cronSchedule": "*/15 * * * *",
    "restartPolicyType": "NEVER"
  }
}
