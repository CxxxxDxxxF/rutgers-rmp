{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.worker",
    "watchPatterns": [
      "Dockerfile.worker",
      "package.json",
      "package-lock.json",
      "railway.worker.json",
      "worker/**"
    ]
  },
  "deploy": {
    "startCommand": null,
    "restartPolicyType": "ALWAYS"
  }
}
