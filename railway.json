{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.web",
    "watchPatterns": [
      "Dockerfile.web",
      "package.json",
      "package-lock.json",
      "railway.json",
      "next.config.ts",
      "tsconfig.json",
      "app/**",
      "components/**",
      "lib/**",
      "public/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
