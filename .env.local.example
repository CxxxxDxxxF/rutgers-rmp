# Supabase — project URL and anon key are safe to expose in client bundles
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — service role key is SECRET: never expose via NEXT_PUBLIC_*
# Used server-side only to bypass RLS for trusted write operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — direct DB connection for migration scripts (not used at runtime)
SUPABASE_DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# OpenRouter — server-side only, never expose via NEXT_PUBLIC_*
OPENROUTER_API_KEY=your-openrouter-api-key

# Admin — server-side only secret for /admin/submissions access
# Generate with: openssl rand -base64 32
ADMIN_SECRET=your-admin-secret

# Vote fingerprinting — server-side salt mixed into the SHA-256 hash of IP+UA
# Prevents raw IPs from being stored. Generate with: openssl rand -base64 32
VOTE_FINGERPRINT_SALT=your-vote-fingerprint-salt

# Stripe — server-side only, never expose via NEXT_PUBLIC_*
# Get keys from https://dashboard.stripe.com/apikeys
# Create a Price at https://dashboard.stripe.com/products and paste the price ID
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Sniper worker — set these in Railway for npm run worker:sniper
NEXT_PUBLIC_APP_URL=https://ru-rate.com
SNIPER_POLL_INTERVAL_MS=500
SNIPER_WATCHLIST_REFRESH_MS=5000
SNIPER_NO_WATCHES_INTERVAL_MS=1000
SNIPER_MAX_BACKOFF_MS=15000
SNIPER_DEFAULT_YEAR=2025
SNIPER_DEFAULT_TERM=9
SNIPER_DEFAULT_CAMPUS=NB

# Email notifications via Resend — server-side only
RESEND_API_KEY=your-resend-api-key
NOTIFY_EMAIL_FROM="RU Rate <alerts@example.com>"
