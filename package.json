{
  "name": "rmp-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "rm -rf .tmp-test-build && tsc -p tsconfig.test.json && node --test .tmp-test-build/lib/*.test.js .tmp-test-build/lib/rmp/*.test.js && node --test worker/lib/*.test.mjs",
    "seed": "npx tsx scripts/seed.ts",
    "ingest": "npx tsx scripts/ingest-soc.ts",
    "ingest:dry": "npx tsx scripts/ingest-soc.ts --dry-run",
    "ingest:cs": "npx tsx scripts/ingest-soc.ts --subjects 198",
    "ingest:all": "npx tsx scripts/ingest-soc.ts",
    "worker:sniper": "node worker/sniper-worker.mjs",
    "worker:collect": "node worker/status-collector.mjs",
    "worker:ai": "node worker/ai-analysis-collector.mjs",
    "migrate": "npx tsx scripts/apply-migration.ts",
    "enrich:rmp": "npx tsx scripts/enrich-rmp.ts",
    "audit:data": "npx tsx scripts/audit-data.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.107.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
